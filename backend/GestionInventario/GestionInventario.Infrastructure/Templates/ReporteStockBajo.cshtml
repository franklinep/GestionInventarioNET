@model GestionInventario.Application.Reportes.DTOs.ReporteStockBajoResponse

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Reporte de Stock Bajo</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Arial, Helvetica, sans-serif;
            color: #2d3748;
            font-size: 11px;
            line-height: 1.5;
            padding: 24px 28px;
        }

        /* ── Header ── */
        .header {
            display: table;
            width: 100%;
            margin-bottom: 24px;
            border-bottom: 3px solid #006EC4;
            padding-bottom: 16px;
        }

        .header-left {
            display: table-cell;
            vertical-align: middle;
        }

        .header-right {
            display: table-cell;
            text-align: right;
            vertical-align: middle;
        }

        .brand {
            font-size: 22px;
            font-weight: 700;
            color: #006EC4;
            letter-spacing: -0.5px;
        }

        .brand-sub {
            font-size: 10px;
            color: #718093;
            margin-top: 2px;
        }

        .report-title {
            font-size: 16px;
            font-weight: 700;
            color: #1a202c;
        }

        .report-date {
            font-size: 10px;
            color: #718093;
            margin-top: 2px;
        }

        /* ── Summary Cards ── */
        .summary {
            display: table;
            width: 100%;
            margin-bottom: 28px;
            table-layout: fixed;
        }

        .summary-card {
            display: table-cell;
            text-align: center;
            padding: 14px 10px;
            border-radius: 6px;
            vertical-align: top;
        }

        .summary-card.total {
            background-color: #e8f4fd;
            border-left: 4px solid #006EC4;
        }

        .summary-card.critico {
            background-color: #fef2f2;
            border-left: 4px solid #dc2626;
        }

        .summary-card.valor {
            background-color: #fef9e7;
            border-left: 4px solid #FEB000;
        }

        .summary-spacer {
            display: table-cell;
            width: 12px;
        }

        .summary-value {
            font-size: 24px;
            font-weight: 700;
            color: #1a202c;
            display: block;
        }

        .summary-label {
            font-size: 9px;
            color: #718093;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 2px;
            display: block;
        }

        /* ── Category Section ── */
        .category-section {
            margin-bottom: 22px;
            page-break-inside: avoid;
        }

        .category-header {
            background-color: #006EC4;
            color: #ffffff;
            padding: 8px 14px;
            border-radius: 4px 4px 0 0;
            font-size: 12px;
            font-weight: 700;
        }

        .category-header span {
            font-weight: 400;
            font-size: 10px;
            opacity: 0.85;
            margin-left: 8px;
        }

        /* ── Table ── */
        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background-color: #f1f5f9;
            color: #475569;
            padding: 8px 12px;
            text-align: left;
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            border-bottom: 2px solid #e2e8f0;
        }

        td {
            padding: 8px 12px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 10.5px;
            color: #334155;
        }

        tr:nth-child(even) {
            background-color: #fafbfc;
        }

        /* ── Badges ── */
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 9px;
            font-weight: 700;
        }

        .badge-critico {
            background-color: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        .badge-bajo {
            background-color: #fef9e7;
            color: #d97706;
            border: 1px solid #fde68a;
        }

        .stock-critico {
            color: #dc2626;
            font-weight: 700;
        }

        .stock-bajo {
            color: #d97706;
            font-weight: 600;
        }

        /* ── Empty State ── */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #16a34a;
            font-size: 14px;
            font-weight: 600;
        }

        /* ── Footer ── */
        .footer {
            margin-top: 30px;
            padding-top: 12px;
            border-top: 1px solid #e2e8f0;
            text-align: center;
            color: #94a3b8;
            font-size: 9px;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="header">
        <div class="header-left">
            <div class="brand">Inventory</div>
            <div class="brand-sub">Sistema de Gestion de Inventario</div>
        </div>
        <div class="header-right">
            <div class="report-title">Reporte de Stock Bajo</div>
            <div class="report-date">Generado el @Model.FechaGeneracion.ToString("dd/MM/yyyy") a las @Model.FechaGeneracion.ToString("HH:mm")</div>
        </div>
    </div>

    <!-- Summary -->
    <div class="summary">
        <div class="summary-card total">
            <span class="summary-value">@Model.TotalProductos</span>
            <span class="summary-label">Productos con Stock Bajo</span>
        </div>
        <div class="summary-spacer"></div>
        <div class="summary-card critico">
            <span class="summary-value">@Model.ProductosCriticos</span>
            <span class="summary-label">Productos Criticos</span>
        </div>
        <div class="summary-spacer"></div>
        <div class="summary-card valor">
            <span class="summary-value">S/ @Model.ValorAfectado.ToString("N2")</span>
            <span class="summary-label">Valor Total Afectado</span>
        </div>
    </div>

    <!-- Product Tables Grouped by Category -->
    @if (Model.Productos.Any())
    {
        @foreach (var grupo in Model.Productos.GroupBy(p => p.CategoriaNombre).OrderBy(g => g.Key))
        {
            <div class="category-section">
                <div class="category-header">
                    @grupo.Key
                    <span>(@grupo.Count() productos)</span>
                </div>
                <table>
                    <thead>
                        <tr>
                            <th style="width: 8%;">ID</th>
                            <th style="width: 28%;">Producto</th>
                            <th style="width: 14%;">Stock</th>
                            <th style="width: 14%;">Nivel</th>
                            <th style="width: 16%;">Precio Unit.</th>
                            <th style="width: 20%;">Ultima Act.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var producto in grupo.OrderBy(p => p.StockActual))
                        {
                            <tr>
                                <td>@producto.ProductoId</td>
                                <td><strong>@producto.Nombre</strong></td>
                                <td class="@(producto.Nivel == "Crítico" ? "stock-critico" : "stock-bajo")">
                                    @producto.StockActual unidades
                                </td>
                                <td>
                                    <span class="badge @(producto.Nivel == "Crítico" ? "badge-critico" : "badge-bajo")">
                                        @producto.Nivel
                                    </span>
                                </td>
                                <td>S/ @producto.Precio.ToString("N2")</td>
                                <td>@producto.UltimaActualizacion.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            No hay productos con stock bajo. Todo esta en orden.
        </div>
    }

    <!-- Footer -->
    <div class="footer">
        <p>Inventory - Sistema de Gestion de Inventario | Reporte generado automaticamente | Confidencial</p>
    </div>
</body>
</html>
